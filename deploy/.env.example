# Poop Deck :: secrets for the compose stack.
# Copy to deploy/.env and fill in real values:  cp deploy/.env.example deploy/.env
# deploy/.env is gitignored — never commit real passwords.
#
# Keep passwords URL-safe (alphanumeric / -_.). PG_PASSWORD is embedded in a DSN,
# so a raw ':' '@' '/' '#' would need percent-encoding — avoid them here.

# TimescaleDB — the poopdeck role's password. Host/TCP connections use scram.
PG_PASSWORD=change-me-pg

# Grafana admin login (user stays 'admin').
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# MQTT — the ingest consumer. Subscribes farm/# (see mosquitto/aclfile).
MQTT_INGEST_USER=ingest
MQTT_INGEST_PASSWORD=change-me-ingest

# MQTT — the tinkle producer. Publishes farm/irrigation/# only.
# Real tinkle firmware is issued these credentials (#13).
MQTT_TINKLE_USER=tinkle
MQTT_TINKLE_PASSWORD=change-me-tinkle
